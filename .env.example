# Database
DATABASE_URL="postgresql://user:password@localhost:5432/drama_platform"

# Anthropic / Claude
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_BASE_URL=""   # 可选，留空使用官方默认地址

# Stable Diffusion (本地服务，默认 http://127.0.0.1:5000)
SD_BASE_URL="http://127.0.0.1:5000"

# 视频生成服务商（默认 seedance）
DEFAULT_PROVIDER="seedance"

# Seedance
SEEDANCE_API_KEY=""
SEEDANCE_MODEL=""

# Runway
RUNWAY_API_KEY=""

# Kling
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""

# Flow2API（可选）
FLOW2API_BASE_URL="http://localhost:8080"
FLOW2API_API_KEY=""
